                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/api/admin/dashboard/total-mascotas"
          }
        },
        {
          "name": "Total usuarios",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/api/admin/dashboard/total-usuarios"
          }
        },
        {
          "name": "Solicitudes pendientes",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
