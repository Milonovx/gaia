{
  "info": {
    "name": "GAIA API",
    "description": "Coleccion Postman para GAIA",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:8443"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan\",\n  \"apellido\": \"Perez\",\n  \"email\": \"juan@example.com\",\n  \"password\": \"Password123\",\n  \"telefono\": \"3001234567\"\n}"
            }
          }
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@gaia.local\",\n  \"password\": \"Admin12345\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('token', json.token);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Mascotas",
      "item": [
        {
          "name": "Listar mascotas",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/api/mascotas"
          }
        },
        {
          "name": "Filtrar mascotas disponibles",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/api/mascotas?raza=Mestizo&tamano=Mediano&genero=Macho&disponible=true"
          }
        },
        {
          "name": "Crear mascota",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/mascotas",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Luna\",\n  \"edad\": 2,\n  \"raza\": \"Mestizo\",\n  \"tamano\": \"Mediano\",\n  \"genero\": \"Hembra\",\n  \"descripcion\": \"Rescatada en buen estado.\",\n  \"estadoSalud\": \"Saludable\",\n  \"vacunado\": true,\n  \"esterilizado\": true,\n  \"imagenUrl\": \"https://example.com/luna.jpg\",\n  \"disponible\": true,\n  \"fechaRescate\": \"2026-05-15\",\n  \"refugioId\": 1\n}"
            }
          }
        },
        {
          "name": "Actualizar mascota",
          "request": {
            "method": "PUT",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/mascotas/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Luna\",\n  \"edad\": 3,\n  \"raza\": \"Mestizo\",\n  \"tamano\": \"Mediano\",\n  \"genero\": \"Hembra\",\n  \"descripcion\": \"Lista para adopcion.\",\n  \"estadoSalud\": \"Saludable\",\n  \"vacunado\": true,\n  \"esterilizado\": true,\n  \"imagenUrl\": \"https://example.com/luna.jpg\",\n  \"disponible\": true,\n  \"fechaRescate\": \"2026-05-15\",\n  \"refugioId\": 1\n}"
            }
          }
        },
        {
          "name": "Eliminar mascota",
          "request": {
            "method": "DELETE",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/api/mascotas/1"
          }
        }
      ]
    },
    {
      "name": "Refugios",
      "item": [
        {
          "name": "Listar refugios",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/api/refugios"
          }
        },
        {
          "name": "Crear refugio",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/refugios",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Refugio Centro Neiva\",\n  \"direccion\": \"Centro, Neiva\",\n  \"telefono\": \"3001112233\",\n  \"descripcion\": \"Refugio urbano.\",\n  \"latitud\": 2.9340,\n  \"longitud\": -75.2800,\n  \"ciudad\": \"Neiva\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Adopciones",
      "item": [
        {
          "name": "Crear solicitud",
          "request": {
            "method": "POST",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/adopciones",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mascotaId\": 1,\n  \"mensaje\": \"Quiero adoptar esta mascota y puedo ofrecerle un hogar responsable.\"\n}"
            }
          }
        },
        {
          "name": "Listar solicitudes",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/api/adopciones"
          }
        },
        {
          "name": "Actualizar estado",
          "request": {
            "method": "PUT",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/adopciones/1/estado",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estado\": \"APROBADA\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Dashboard Admin",
      "item": [
        {
          "name": "Resumen",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/api/admin/dashboard"
          }
        },
        {
          "name": "Total mascotas",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
