                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/api/admin/dashboard/solicitudes-pendientes"
          }
        },
        {
          "name": "Mascotas disponibles",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "url": "{{baseUrl}}/api/admin/dashboard/mascotas-disponibles"
          }
        }
      ]
    }
  ]
}
